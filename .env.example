# LLM Provider Configuration
# options: openai, local, dry-run
LLM_PROVIDER=local
LOCAL_LLM_MODEL=gemma4:e4b
LOCAL_LLM_BASE_URL=http://localhost:11434

# OpenAI Configuration (Only needed if LLM_PROVIDER=openai)
OPENAI_API_KEY=

# News & Search APIs Configuration (For real-time article fetching)
NEWS_API_KEY=
BRAVE_SEARCH_API_KEY=

# Optional: required for remote browsers to update .env through /api/config.
# Localhost can update .env without this token.
CONFIG_WRITE_TOKEN=

# Gemini Configuration (Only needed if LLM_PROVIDER=gemini)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# NVIDIA NIM Configuration (Only needed if LLM_PROVIDER=nim)
NVIDIA_NIM_API_KEY=
NVIDIA_NIM_MODEL=meta/llama-3.1-8b-instruct
